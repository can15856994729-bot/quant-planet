    "cap:sync": "cap sync android",
    "build:apk": "cap sync android && node -e \"require('fs').rmSync('android/app/src/main/assets/public/downloads',{recursive:true,force:true})\" && cd android && ./gradlew assembleDebug && cd .. && cp android/app/build/outputs/apk/debug/app-debug.apk public/downloads/QuantPlanet.apk"
  },
